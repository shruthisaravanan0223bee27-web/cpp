#include<iostream>
using namespace std;
int main()
{
    int a,b,c,o,e,i;
    cin>>a;
    b=a;
    o=0;
    e=0;
    while(b!=0)
    {
        c=b%10;
        if(c%2==0)
        {
            e=e+c;
        }
        else
        {
            o=o+c;
        }
        b=b/10;
    }
    cout<<o<<" "<<e;
}
