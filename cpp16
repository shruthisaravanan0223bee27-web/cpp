#include<iostream>
#include<string.h>
using namespace std;
class stu
{
   private:
      int regno;
      float marks;
      string name;
   public:
      stu()
      {}
      stu(int rgno, string n, float m){
         regno=rgno;
         name=n;
         marks=m;
      }
      void display()
      {
         cout<<"regno:"<<regno<<endl;
         cout<<"name:"<<name<<endl;
         cout<<"marks:"<<marks<<endl;
      }
      stu(stu&ss)
      {
         regno=ss.regno;
         name=ss.name;
         marks=ss.marks;
      }
};
      int main()
      {
         stu s(1902,"chota bheem",96);
         s.display();
         stu s1(s);
         s1.display();
         stu s2=s;
         s2.display();
      }
